{
  "name": "@nexa-ed/node",
  "version": "0.2.0-beta.3",
  "description": "Nexa Education Platform — Node.js & Framework-Agnostic Adapter",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js",
      "require": "./dist/fastify.cjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./express": {
        "types": "./dist/express.d.ts",
        "import": "./dist/express.js",
        "require": "./dist/express.cjs"
      },
      "./fastify": {
        "types": "./dist/fastify.d.ts",
        "import": "./dist/fastify.js",
        "require": "./dist/fastify.cjs"
      },
      "./hono": {
        "types": "./dist/hono.d.ts",
        "import": "./dist/hono.js",
        "require": "./dist/hono.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
    "@nexa-ed/sdk": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=5.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nexa-ed/config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "express": "^4.21.0",
    "fastify": "^5.8.3",
    "hono": "^4.12.12",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
