{
  "name": "@nexa-ed/react",
  "version": "0.1.0",
  "description": "Nexa Education Platform — React UI Components",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "types": "./dist/index.d.ts"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
    "@nexa-ed/sdk": "workspace:*",
    "@orpc/client": "catalog:",
    "@orpc/tanstack-query": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "lucide-react": ">=0.400.0",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lucide-react": "^0.487.0",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
